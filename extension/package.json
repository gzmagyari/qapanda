{
  "name": "qapanda-vscode",
  "displayName": "QA Panda",
  "description": "AI-powered QA agents for your codebase — test, fix, and ship with confidence",
  "version": "0.2.0",
  "publisher": "qapanda",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished",
    "onWebviewPanel:qapandaPanel"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "qapanda.open",
        "title": "QA Panda: Open",
        "icon": {
          "light": "./resources/icon.svg",
          "dark": "./resources/icon.svg"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "qapanda.open",
          "group": "navigation"
        }
      ]
    }
  },
  "dependencies": {
    "@xterm/headless": "^5.0.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  }
}
