{
  "name": "qapanda-vscode",
  "displayName": "QA Panda",
  "description": "AI-powered QA agents for your codebase — test, fix, and ship with confidence",
  "version": "0.3.1",
  "publisher": "qapandaapp",
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gzmagyari/qapanda"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "onCommand:qapanda.open",
    "onStartupFinished",
    "onWebviewPanel:qapandaPanel"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "qapanda.open",
        "title": "QA Panda: Open",
        "icon": {
          "light": "./resources/icon.svg",
          "dark": "./resources/icon.svg"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "qapanda.open",
          "group": "navigation"
        }
      ]
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/headless": "^5.0.0",
    "node-pty": "^1.0.0",
    "openai": "^6.33.0",
    "pdfkit": "^0.17.2"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  }
}
