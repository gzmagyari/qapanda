{
  "name": "qapanda-vscode",
  "displayName": "QA Panda",
  "description": "AI-powered QA agents for your codebase — test, fix, and ship with confidence",
  "version": "0.3.4",
  "publisher": "qapandaapp",
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gzmagyari/qapanda"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "onCommand:qapanda.open",
    "onCommand:qapanda.openWorkspace",
    "onView:qapandaLauncherView",
    "onStartupFinished",
    "onWebviewPanel:qapandaPanel"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "qapandaActivity",
          "title": "QA Panda",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "qapandaActivity": [
        {
          "id": "qapandaLauncherView",
          "name": "QA Panda",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "qapanda.open",
        "title": "QA Panda: Open",
        "icon": {
          "light": "./resources/icon.svg",
          "dark": "./resources/icon.svg"
        }
      },
      {
        "command": "qapanda.openWorkspace",
        "title": "QA Panda: Open Workspace...",
        "enablement": "qapanda.namedWorkspacesEnabled"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "qapanda.open",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "qapanda.openWorkspace",
          "when": "qapanda.namedWorkspacesEnabled"
        }
      ]
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@google/genai": "^1.49.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/headless": "^5.0.0",
    "node-pty": "^1.0.0",
    "openai": "^6.33.0",
    "pdfkit": "^0.17.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  }
}
