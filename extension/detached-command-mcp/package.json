{
  "name": "detached-command-mcp-server",
  "version": "1.0.0",
  "description": "Cross-platform MCP server for fully detached command execution with persistent logs and job control.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "detached-command-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "clean": "node -e \"import('node:fs/promises').then(fs=>fs.rm('dist',{recursive:true,force:true}))\"",
    "start": "node dist/index.js",
    "dev": "node --loader tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "detached",
    "process-manager",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
