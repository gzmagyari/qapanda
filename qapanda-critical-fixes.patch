diff --git a/extension/qa-state-store.js b/extension/qa-state-store.js
new file mode 100644
index 0000000000000000000000000000000000000000..d54f44cb021862c54107b1075ae2eae2418542b7
--- /dev/null
+++ b/extension/qa-state-store.js
@@ -0,0 +1,273 @@
+const fs = require('node:fs');
+const path = require('node:path');
+
+const VALID_TASK_STATUSES = ['backlog', 'todo', 'in_progress', 'review', 'testing', 'done'];
+const VALID_TEST_STATUSES = ['untested', 'passing', 'failing', 'partial'];
+const VALID_STEP_STATUSES = ['untested', 'pass', 'fail', 'skip'];
+const VALID_ENVIRONMENTS = ['browser', 'computer'];
+const VALID_BUG_SEVERITIES = ['critical', 'high', 'medium', 'low'];
+
+function nowIso() {
+  return new Date().toISOString();
+}
+
+function defaultTasksDoc() {
+  return { nextId: 1, nextCommentId: 1, nextProgressId: 1, tasks: [] };
+}
+
+function defaultTestsDoc() {
+  return { nextId: 1, nextStepId: 1, nextRunId: 1, tests: [] };
+}
+
+function readJsonFile(filePath, fallbackFactory) {
+  try {
+    return JSON.parse(fs.readFileSync(filePath, 'utf8'));
+  } catch {
+    return fallbackFactory();
+  }
+}
+
+function writeJsonAtomic(filePath, data) {
+  const dir = path.dirname(filePath);
+  fs.mkdirSync(dir, { recursive: true });
+  const tempPath = path.join(dir, `.${path.basename(filePath)}.${process.pid}.${Date.now()}.tmp`);
+  fs.writeFileSync(tempPath, JSON.stringify(data, null, 2), 'utf8');
+  try {
+    fs.renameSync(tempPath, filePath);
+  } catch (error) {
+    try { fs.rmSync(filePath, { force: true }); } catch {}
+    fs.renameSync(tempPath, filePath);
+  } finally {
+    try {
+      if (fs.existsSync(tempPath)) fs.rmSync(tempPath, { force: true });
+    } catch {}
+  }
+}
+
+function loadTasksDoc(tasksFile) {
+  return ensureTasksDoc(readJsonFile(tasksFile, defaultTasksDoc));
+}
+
+function saveTasksDoc(tasksFile, data) {
+  writeJsonAtomic(tasksFile, ensureTasksDoc(data));
+}
+
+function loadTestsDoc(testsFile) {
+  return ensureTestsDoc(readJsonFile(testsFile, defaultTestsDoc));
+}
+
+function saveTestsDoc(testsFile, data) {
+  writeJsonAtomic(testsFile, ensureTestsDoc(data));
+}
+
+function uniqueIds(values) {
+  const seen = new Set();
+  const result = [];
+  for (const value of values || []) {
+    const id = String(value || '').trim();
+    if (!id || seen.has(id)) continue;
+    seen.add(id);
+    result.push(id);
+  }
+  return result;
+}
+
+function normalizeSeverity(value) {
+  if (value == null || value === '') return null;
+  const normalized = String(value).trim().toLowerCase();
+  if (!VALID_BUG_SEVERITIES.includes(normalized)) {
+    throw new Error(`Invalid severity: ${value}`);
+  }
+  return normalized;
+}
+
+function ensureTaskDefaults(task) {
+  const value = task && typeof task === 'object' ? task : {};
+  value.comments = Array.isArray(value.comments) ? value.comments : [];
+  value.progress_updates = Array.isArray(value.progress_updates) ? value.progress_updates : [];
+  value.linkedTestIds = uniqueIds(value.linkedTestIds || []);
+  value.severity = value.severity == null ? null : normalizeSeverity(value.severity);
+  return value;
+}
+
+function ensureTestDefaults(test) {
+  const value = test && typeof test === 'object' ? test : {};
+  value.steps = Array.isArray(value.steps) ? value.steps : [];
+  value.runs = Array.isArray(value.runs) ? value.runs : [];
+  value.linkedTaskIds = uniqueIds(value.linkedTaskIds || []);
+  value.tags = Array.isArray(value.tags) ? value.tags : [];
+  for (const step of value.steps) {
+    step.status = VALID_STEP_STATUSES.includes(step && step.status) ? step.status : 'untested';
+    if (!Object.prototype.hasOwnProperty.call(step || {}, 'actualResult')) {
+      step.actualResult = null;
+    }
+  }
+  return value;
+}
+
+function ensureTasksDoc(doc) {
+  const value = doc && typeof doc === 'object' ? doc : defaultTasksDoc();
+  value.nextId = Number.isFinite(value.nextId) ? value.nextId : 1;
+  value.nextCommentId = Number.isFinite(value.nextCommentId) ? value.nextCommentId : 1;
+  value.nextProgressId = Number.isFinite(value.nextProgressId) ? value.nextProgressId : 1;
+  value.tasks = Array.isArray(value.tasks) ? value.tasks : [];
+  value.tasks.forEach(ensureTaskDefaults);
+  return value;
+}
+
+function ensureTestsDoc(doc) {
+  const value = doc && typeof doc === 'object' ? doc : defaultTestsDoc();
+  value.nextId = Number.isFinite(value.nextId) ? value.nextId : 1;
+  value.nextStepId = Number.isFinite(value.nextStepId) ? value.nextStepId : 1;
+  value.nextRunId = Number.isFinite(value.nextRunId) ? value.nextRunId : 1;
+  value.tests = Array.isArray(value.tests) ? value.tests : [];
+  value.tests.forEach(ensureTestDefaults);
+  return value;
+}
+
+function computeOverallStatus(steps) {
+  if (!steps || steps.length === 0) return 'untested';
+  const statuses = steps.map((step) => VALID_STEP_STATUSES.includes(step && step.status) ? step.status : 'untested');
+  if (statuses.every((status) => status === 'untested')) return 'untested';
+  if (statuses.every((status) => status === 'pass' || status === 'skip')) return 'passing';
+  if (statuses.every((status) => status === 'fail')) return 'failing';
+  if (statuses.some((status) => status === 'fail')) return 'partial';
+  if (statuses.some((status) => status === 'pass')) return 'partial';
+  return 'untested';
+}
+
+function computeRunStatus(stepResults) {
+  if (!stepResults || stepResults.length === 0) return 'untested';
+  const statuses = stepResults.map((step) => VALID_STEP_STATUSES.includes(step && step.status) ? step.status : 'untested');
+  if (statuses.every((status) => status === 'pass' || status === 'skip')) return 'passing';
+  if (statuses.every((status) => status === 'fail')) return 'failing';
+  if (statuses.some((status) => status === 'fail')) return 'partial';
+  if (statuses.some((status) => status === 'pass')) return 'partial';
+  return 'untested';
+}
+
+function updateTestStatus(test) {
+  ensureTestDefaults(test);
+  test.status = computeOverallStatus(test.steps);
+  return test.status;
+}
+
+function syncTestStepsFromRun(test, run) {
+  ensureTestDefaults(test);
+  const resultsByStepId = new Map((run && Array.isArray(run.stepResults) ? run.stepResults : [])
+    .map((stepResult) => [Number(stepResult.stepId), stepResult]));
+  for (const step of test.steps) {
+    const stepResult = resultsByStepId.get(Number(step.id));
+    if (!stepResult) {
+      step.status = 'untested';
+      step.actualResult = null;
+      continue;
+    }
+    step.status = VALID_STEP_STATUSES.includes(stepResult.status) ? stepResult.status : 'untested';
+    step.actualResult = stepResult.actualResult == null ? null : stepResult.actualResult;
+  }
+  updateTestStatus(test);
+}
+
+function ensureTaskTestLink(task, test) {
+  ensureTaskDefaults(task);
+  ensureTestDefaults(test);
+  task.linkedTestIds = uniqueIds([...(task.linkedTestIds || []), test.id]);
+  test.linkedTaskIds = uniqueIds([...(test.linkedTaskIds || []), task.id]);
+}
+
+function removeTaskTestLink(task, test) {
+  if (task) {
+    ensureTaskDefaults(task);
+    task.linkedTestIds = uniqueIds((task.linkedTestIds || []).filter((id) => String(id) !== String(test && test.id)));
+  }
+  if (test) {
+    ensureTestDefaults(test);
+    test.linkedTaskIds = uniqueIds((test.linkedTaskIds || []).filter((id) => String(id) !== String(task && task.id)));
+  }
+}
+
+function cleanupDeletedTask(taskId, testsDoc) {
+  ensureTestsDoc(testsDoc);
+  for (const test of testsDoc.tests) {
+    ensureTestDefaults(test);
+    test.linkedTaskIds = uniqueIds((test.linkedTaskIds || []).filter((id) => String(id) !== String(taskId)));
+  }
+}
+
+function cleanupDeletedTest(testId, tasksDoc) {
+  ensureTasksDoc(tasksDoc);
+  for (const task of tasksDoc.tasks) {
+    ensureTaskDefaults(task);
+    task.linkedTestIds = uniqueIds((task.linkedTestIds || []).filter((id) => String(id) !== String(testId)));
+  }
+}
+
+function findTask(tasksDoc, taskId) {
+  ensureTasksDoc(tasksDoc);
+  return tasksDoc.tasks.find((task) => String(task.id) === String(taskId)) || null;
+}
+
+function findTest(testsDoc, testId) {
+  ensureTestsDoc(testsDoc);
+  return testsDoc.tests.find((test) => String(test.id) === String(testId)) || null;
+}
+
+function findRun(test, runId) {
+  ensureTestDefaults(test);
+  return (test.runs || []).find((run) => Number(run.id) === Number(runId)) || null;
+}
+
+function buildFailingBugDescription(test) {
+  const failingSteps = (test && Array.isArray(test.steps) ? test.steps : []).filter((step) => step.status === 'fail');
+  return `Bug from test: ${test.title}\n\nFailing steps:\n${failingSteps.map((step) => `- ${step.description}: expected "${step.expectedResult}", got "${step.actualResult || 'N/A'}"`).join('\n')}`;
+}
+
+function buildTestCardPayload(test) {
+  ensureTestDefaults(test);
+  return {
+    title: test.title,
+    test_id: test.id,
+    passed: test.steps.filter((step) => step.status === 'pass').length,
+    failed: test.steps.filter((step) => step.status === 'fail').length,
+    skipped: test.steps.filter((step) => !step.status || step.status === 'skip' || step.status === 'untested').length,
+    steps: test.steps.map((step) => ({
+      name: step.description,
+      status: step.status === 'untested' ? 'skip' : (step.status || 'skip'),
+    })),
+  };
+}
+
+module.exports = {
+  VALID_TASK_STATUSES,
+  VALID_TEST_STATUSES,
+  VALID_STEP_STATUSES,
+  VALID_ENVIRONMENTS,
+  VALID_BUG_SEVERITIES,
+  nowIso,
+  defaultTasksDoc,
+  defaultTestsDoc,
+  loadTasksDoc,
+  saveTasksDoc,
+  loadTestsDoc,
+  saveTestsDoc,
+  ensureTaskDefaults,
+  ensureTestDefaults,
+  ensureTasksDoc,
+  ensureTestsDoc,
+  uniqueIds,
+  normalizeSeverity,
+  computeOverallStatus,
+  computeRunStatus,
+  updateTestStatus,
+  syncTestStepsFromRun,
+  ensureTaskTestLink,
+  removeTaskTestLink,
+  cleanupDeletedTask,
+  cleanupDeletedTest,
+  findTask,
+  findTest,
+  findRun,
+  buildFailingBugDescription,
+  buildTestCardPayload,
+};
