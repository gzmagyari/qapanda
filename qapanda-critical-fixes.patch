+      return JSON.stringify(matches.map(({ item, score, matchReason }) => ({
+        id: item.id,
+        title: item.title,
+        description: item.description,
+        environment: item.environment,
+        status: item.status,
+        tags: item.tags || [],
+        linkedTaskIds: item.linkedTaskIds || [],
+        updated_at: item.updated_at,
