{
  "name": "qapanda",
  "version": "0.2.5",
  "description": "Interactive manager CLI that uses Codex to control Claude Code",
  "bin": {
    "qapanda": "./bin/qapanda.js"
  },
  "type": "commonjs",
  "scripts": {
    "web": "node web/server.js",
    "test": "node --test",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:crud": "node --test tests/crud/*.test.js",
    "test:live": "node --test tests/live/*.test.js",
    "test:live:mcp": "node --test tests/live/mcp-*.test.js",
    "test:live:cli": "node --test tests/live/claude-*.test.js tests/live/codex-*.test.js tests/live/interactive-*.test.js",
    "test:live:browser": "node --test tests/live/browser-*.test.js",
    "test:live:desktop": "node --test tests/live/desktop-*.test.js tests/live/remote-*.test.js",
    "test:live:flows": "node --test tests/live/full-flows.test.js",
    "test:ui": "node --test tests/ui/*.test.js",
    "test:live:cli-e2e": "node --test tests/live/cli-*.test.js",
    "test:api": "node --test tests/live/api-*.test.js",
    "verify:models": "node scripts/verify-model-catalog.js",
    "test:all": "node tests/run-all.js",
    "test:cleanup": "node tests/cleanup.js",
    "ext:copy-src": "node -e \"const fs=require('fs');const p=require('path');function cp(s,d){fs.mkdirSync(d,{recursive:true});for(const e of fs.readdirSync(s,{withFileTypes:true})){const sp=p.join(s,e.name),dp=p.join(d,e.name);e.isDirectory()?cp(sp,dp):fs.copyFileSync(sp,dp)}}cp('src','extension/src');const cd='extension/claude-parser';fs.mkdirSync(cd,{recursive:true});for(const f of['index.js','parse-stream.js','package.json'])fs.copyFileSync(p.join('claude-parser',f),p.join(cd,f));cp('qa-desktop','extension/qa-desktop');cp('resources','extension/resources');cp('prompts','extension/prompts')\"",
    "ext:build": "node -e \"const fs=require('fs');try{fs.rmSync('extension/cc-manager.vsix',{force:true})}catch{}\" && npm run ext:copy-src && cd extension && npx @vscode/vsce package --allow-missing-repository -o qapanda.vsix",
    "ext:install": "npm run ext:build && node scripts/ext-install.js",
    "deploy": "npm run ext:build && node scripts/ext-install.js && npm install -g .",
    "platform:cloud:pack": "node scripts/platform-cloud/pack-client-safe-packages.js",
    "platform:cloud:install": "node scripts/platform-cloud/install-client-safe-packages.js",
    "platform:cloud:verify-imports": "node scripts/platform-cloud/verify-client-safe-imports.mjs",
    "platform:cloud:refresh": "npm run platform:cloud:pack && npm run platform:cloud:install && npm run platform:cloud:verify-imports",
    "platform:start": "pnpm --dir \"propanda/qapanda-platform\" infra:start:local",
    "platform:status": "pnpm --dir \"propanda/qapanda-platform\" infra:status:local",
    "platform:stop": "pnpm --dir \"propanda/qapanda-platform\" infra:stop:local",
    "platform:restart": "pnpm --dir \"propanda/qapanda-platform\" infra:restart:local",
    "ext:clean": "node -e \"fs.rmSync('extension/src',{recursive:true,force:true});fs.rmSync('extension/claude-parser',{recursive:true,force:true});fs.rmSync('extension/qapanda.vsix',{force:true});fs.rmSync('extension/cc-manager.vsix',{force:true})\" --input-type=commonjs"
  },
  "engines": {
    "node": ">=18.17"
  },
  "license": "MIT",
  "devDependencies": {
    "jsdom": "^29.0.1",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@qapanda/client-cloud": "file:.qpanda/platform-client-safe/qapanda-client-cloud-1.0.0.tgz",
    "@qapanda/cloud-sdk": "file:.qpanda/platform-client-safe/qapanda-cloud-sdk-1.0.0.tgz",
    "@qapanda/contracts": "file:.qpanda/platform-client-safe/qapanda-contracts-1.0.0.tgz",
    "@qapanda/run-protocol": "file:.qpanda/platform-client-safe/qapanda-run-protocol-1.0.0.tgz",
    "@qapanda/security": "file:.qpanda/platform-client-safe/qapanda-security-1.0.0.tgz",
    "@qapanda/sync-core": "file:.qpanda/platform-client-safe/qapanda-sync-core-1.0.0.tgz",
    "@qapanda/ui": "file:.qpanda/platform-client-safe/qapanda-ui-1.0.0.tgz",
    "openai": "^6.33.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  }
}
