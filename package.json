{
  "name": "cc-manager",
  "version": "0.2.3",
  "description": "Interactive manager CLI that uses Codex to control Claude Code",
  "bin": {
    "cc-manager": "./bin/cc-manager.js"
  },
  "type": "commonjs",
  "scripts": {
    "test": "node --test",
    "ext:copy-src": "node -e \"const fs=require('fs');const p=require('path');function cp(s,d){fs.mkdirSync(d,{recursive:true});for(const e of fs.readdirSync(s,{withFileTypes:true})){const sp=p.join(s,e.name),dp=p.join(d,e.name);e.isDirectory()?cp(sp,dp):fs.copyFileSync(sp,dp)}}cp('src','extension/src')\"",
    "ext:build": "npm run ext:copy-src && cd extension && npx @vscode/vsce package --allow-missing-repository -o cc-manager.vsix",
    "ext:install": "npm run ext:build && code --install-extension extension/cc-manager.vsix",
    "ext:clean": "node -e \"fs.rmSync('extension/src',{recursive:true,force:true});fs.rmSync('extension/cc-manager.vsix',{force:true})\" --input-type=commonjs"
  },
  "engines": {
    "node": ">=18.17"
  },
  "license": "MIT"
}
